#!/bin/sh
# Repository-local hook that runs formatting and linting
# To activate, run:
#   git config core.hooksPath .githooks

echo "Running cargo fmt..."
cargo fmt -- || {
    echo "cargo fmt failed; please ensure rustfmt is installed" >&2
    exit 1
}

# Stage only modified Rust sources so unrelated files are not pulled into
# the commit by this hook.
rust_changed_files="$(git ls-files -m -- '*.rs')"
if [ -n "$rust_changed_files" ]; then
    while IFS= read -r file; do
        [ -n "$file" ] && git add -- "$file"
    done <<EOF
$rust_changed_files
EOF
fi

echo "Running Markdown format/lint..."
staged_markdown_files="$(git diff --cached --name-only -- '*.md')"
if [ -n "$staged_markdown_files" ]; then
    # Format staged Markdown files if prettier is available.
    if command -v prettier >/dev/null 2>&1; then
        while IFS= read -r file; do
            [ -n "$file" ] || continue
            prettier --write "$file" || {
                echo "prettier failed on $file" >&2
                exit 1
            }
            git add -- "$file"
        done <<EOF
$staged_markdown_files
EOF
    else
        echo "warning: prettier not found; skipping Markdown formatting" >&2
    fi

    # Lint staged Markdown files.
    if command -v markdownlint >/dev/null 2>&1; then
        while IFS= read -r file; do
            [ -n "$file" ] || continue
            markdownlint "$file" || {
                echo "markdownlint found issues in $file" >&2
                exit 1
            }
        done <<EOF
$staged_markdown_files
EOF
    elif command -v markdownlint-cli2 >/dev/null 2>&1; then
        while IFS= read -r file; do
            [ -n "$file" ] || continue
            markdownlint-cli2 "$file" || {
                echo "markdownlint-cli2 found issues in $file" >&2
                exit 1
            }
        done <<EOF
$staged_markdown_files
EOF
    else
        echo "warning: markdownlint not found; skipping Markdown lint" >&2
    fi
fi

echo "Running cargo clippy..."
cargo clippy -- -D warnings || {
    echo "clippy found issues; fix them before committing." >&2
    exit 1
}
